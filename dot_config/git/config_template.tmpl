# vim: set filetype=gitconfig :

# This file is managed through chezmoi: check the file with the same name and
# .tmpl extension.

{{ if lookPath "nvim" -}}
# Nvim
[core]
	editor = nvim -f
{{- else if lookPath "vim" }}
# Vim
[core]
	editor = vim -f
{{- end }}

{{ if lookPath "delta" -}}
# Delta
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
{{- end }}

{{- "" -}}
